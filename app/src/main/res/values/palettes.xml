        <item>monochrome</item>
        <item>msx</item>
        <item>teletext</item>
        <item>vic_20</item>
        <item>zx_spectrum</item>
    </string-array>

    <!-- ── No Filter ─────────────────────────────────────── -->
    <string name="palette_label_no_filter">No Filter</string>
    <string-array name="palette_colors_no_filter">
        <!-- empty = passthrough, no colour quantisation -->
    </string-array>

