    <!-- Palette registry: controls display order. Each ID must have a matching
         palette_label_<id> string and palette_colors_<id> string-array below.
         An empty color array means passthrough (no filter). -->
    <string-array name="palette_ids">
        <item>no_filter</item>
        <item>apple_ii</item>
        <item>cga</item>
        <item>cga_16</item>
        <item>commodore_64</item>
        <item>game_boy</item>
