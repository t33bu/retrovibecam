<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimary">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <android.opengl.GLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/rvPalettes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Recording indicator overlay (top-left of preview) -->
    <LinearLayout
        android:id="@+id/recordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_recording_indicator"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <View
            android:id="@+id/recordingDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_record_dot"/>

        <TextView
            android:id="@+id/tvRecordingTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FF4444"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- Exposure lock (lower-right, vertically centred in button row) -->
    <ImageButton
        android:id="@+id/btnLock"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_icon_button"
        android:src="@drawable/ic_lock_open"
        android:padding="12dp"
        android:contentDescription="Lock Exposure"
        app:layout_constraintTop_toTopOf="@id/buttonRow"
        app:layout_constraintBottom_toBottomOf="@id/buttonRow"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Palette strip -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPalettes"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Camera-style button row -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnFlip"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_flip"
            android:padding="12dp"
            android:contentDescription="Switch Camera"/>

        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_shutter_button"
            android:src="@drawable/ic_camera"
            android:padding="16dp"
            android:contentDescription="Take Photo"/>

        <ImageButton
            android:id="@+id/btnRecord"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="32dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_record"
            android:padding="12dp"
            android:contentDescription="Record Video"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
